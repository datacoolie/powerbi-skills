  "picking_algorithm": [
    "1. Intersect by_industry[<domain>] with by_audience[<audience>]",
    "2. If cvd required, intersect with by_cvd_requirement.strict_safe_only",
    "3. Filter by_mode if user requires light/dark",
    "4. If printed output, intersect with by_print_requirement.print_safe",
    "5. Within remaining set, sort by formality tier matching target",
    "6. Tiebreak: prefer domain-specific themes over brand/design-system; prefer light over -dark companions unless audience=monitoring-wall"
  ],
