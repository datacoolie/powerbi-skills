{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://powerbi-skills.local/chart-templates-index.schema.json",
  "title": "Chart Templates Index",
  "description": "Catalog of chart-composition recipes. Strategist binds every visual in Design Spec §5 to one of these.",
  "type": "object",
  "required": ["version", "recipes"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "description": { "type": "string" },
    "recipes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/recipeEntry" }
    },
    "gaps": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "recipeEntry": {
      "type": "object",
      "required": ["id", "file", "title", "visual_type", "composition", "use_when", "anti_use"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "file": {
          "type": "string",
          "pattern": "^[a-z0-9\\-]+\\.md$"
        },
        "title": { "type": "string", "minLength": 1 },
        "visual_type": {
          "type": "string",
          "minLength": 1,
          "description": "Target Power BI visualType (may list alternatives separated by OR)."
        },
        "composition": { "type": "string", "minLength": 1 },
        "use_when": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "anti_use": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "slots": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Canvas slot count the recipe occupies (1 = single-visual, 2+ = multi-visual composition)."
        },
        "tier": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "Priority tier. high = built-in / heavily-used; medium = FT vocabulary gap with custom visual; low = specialist / Deneb-hosted."
        },
        "category": {
          "type": "string",
          "enum": [
            "deviation",
            "correlation",
            "ranking",
            "distribution",
            "change-over-time",
            "magnitude",
            "part-to-whole",
            "spatial",
            "flow",
            "narrative",
            "self-service",
            "kpi"
          ],
          "description": "FT Visual Vocabulary data-relationship category (plus kpi / narrative / self-service for non-chart recipes)."
        }
      }
    }
  }
}
