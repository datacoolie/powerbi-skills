{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://powerbi-skills.local/layouts-index.schema.json",
  "title": "Layouts Index",
  "description": "Catalog of page layout recipes. Strategist selects one layout per page in Design Spec §4.",
  "type": "object",
  "required": [
    "version",
    "layouts"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
      "description": "Catalog schema version (SemVer). Bump MINOR on additive field changes, MAJOR on breaking changes."
    },
    "description": {
      "type": "string"
    },
    "layouts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/layoutEntry"
      }
    },
    "collections": {
      "type": "array",
      "description": "Reserved for ppt-master-style brand kits (coordinated multi-page layout sets). Each collection is an ordered list of layout ids that belong together. Empty until the catalog starts shipping kits.",
      "items": {
        "$ref": "#/$defs/collection"
      }
    },
    "gaps": {
      "type": "array",
      "description": "Free-form list of layouts still needed. Empty array = catalog complete.",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "collection": {
      "type": "object",
      "required": [
        "id",
        "title",
        "layouts"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "layouts": {
          "type": "array",
          "description": "Ordered list of layout ids that compose this kit (e.g. cover, exec, detail, drillthrough).",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "minItems": 2
        },
        "summary": {
          "type": "string"
        },
        "use_case": {
          "type": "string"
        }
      }
    },
    "layoutEntry": {
      "type": "object",
      "required": [
        "id",
        "file",
        "preview",
        "title",
        "canvas",
        "canvas_class",
        "style",
        "domain",
        "visual_count",
        "zones",
        "use_when",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "Kebab-case identifier, unique within the catalog."
        },
        "file": {
          "type": "string",
          "pattern": "^[a-z0-9\\-]+\\.md$",
          "description": "Relative filename of the recipe markdown in references/layouts/."
        },
        "preview": {
          "type": "string",
          "pattern": "^[a-z0-9\\-]+\\.svg$",
          "description": "Relative filename of the wireframe preview SVG in assets/layout-previews/. Must exist on disk; coverage enforced by design_quality_check.py."
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "canvas": {
          "type": "object",
          "required": [
            "width",
            "height"
          ],
          "additionalProperties": false,
          "properties": {
            "width": {
              "type": "integer",
              "minimum": 320,
              "maximum": 3840
            },
            "height": {
              "type": "integer",
              "minimum": 240,
              "maximum": 2160
            }
          }
        },
        "canvas_class": {
          "type": "string",
          "enum": [
            "landscape-16x9",
            "landscape-4x3",
            "mobile-portrait",
            "tooltip-small",
            "tooltip-wide",
            "popup-compact",
            "print-a4",
            "print-a4-landscape",
            "tv-wall-1080p",
            "tv-wall-4k"
          ],
          "description": "Coarse canvas bucket — lets consumers filter by form factor without pattern-matching dimensions."
        },
        "style": {
          "type": "string",
          "enum": [
            "executive",
            "analytical",
            "operational"
          ]
        },
        "domain": {
          "type": "string",
          "enum": [
            "cross-domain",
            "sales",
            "finance",
            "marketing",
            "customer",
            "operations",
            "manufacturing",
            "geography",
            "hr",
            "technology",
            "healthcare",
            "supply-chain",
            "esg"
          ],
          "description": "Primary business domain. Use 'cross-domain' for layouts that work across any subject area (exec-overview, drillthrough, scorecard, etc.)."
        },
        "audience": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "visual_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "zones": {
          "type": "array",
          "items": {
