        "tags": {
          "type": "array",
          "description": "Free-form multi-axis labels for search / filter (e.g. 'kpi-heavy', 'drillthrough-target', 'map', 'real-time'). Keep kebab-case and ASCII.",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "uniqueItems": true
        },
        "recommended_themes": {
          "type": "array",
          "description": "Theme ids from references/themes/themes-index.json that pair well with this layout. Optional — empty or omitted means 'any theme'.",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "uniqueItems": true
        },
        "use_when": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "stable",
            "experimental",
            "deprecated"
          ],
          "description": "Lifecycle. 'stable' = safe to use; 'experimental' = Strategist must warn user; 'deprecated' = Strategist must refuse and suggest replacement."
        },
        "replaced_by": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "When status=='deprecated', the id of the layout that supersedes this one."
        },
        "zones_detail": {
          "type": "array",
          "description": "Precise grid coordinates per zone — consumed by Executor to emit PBIR JSON directly. Each entry names one of `zones` and gives its bbox within `canvas`.",
          "items": {
            "type": "object",
