      "$value": "'IBM Plex Mono', 'Consolas', monospace"
    }
  },
  "motion": {
    "tooltip-delay": {
      "$type": "duration",
      "$value": "250ms"
    },
    "drill-transition": {
      "$type": "duration",
      "$value": "250ms"
    },
    "fade-in": {
      "$type": "duration",
      "$value": "180ms"
    },
    "easing": {
      "$type": "cubicBezier",
      "$value": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },
  "meta": {
    "contrast-ratio": {
      "$type": "number",
      "$value": 14.1
    },
    "cvd-rating": {
      "$type": "string",
      "$value": "unsafe"
    },
    "print-safe": {
      "$type": "boolean",
      "$value": true
    },
    "parent-theme": {
      "$type": "string",
      "$value": "tech-monitoring"
    }
  }
