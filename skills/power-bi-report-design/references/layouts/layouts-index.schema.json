        "density_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "0..1 derived from visual_count / canvas_area. 0 = very airy (exec cover); 1 = wall-board dense. Used to intersect with themes.personality_axes.spaciousness."
        },
        "interaction_model": {
          "type": "object",
          "description": "Explicit wiring for drillthrough / tooltip targets, cross-filter groups, bookmark states.",
          "additionalProperties": false,
          "properties": {
            "drillthrough_target": {
              "type": "string",
              "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
            },
            "tooltip_target": {
              "type": "string",
              "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
            },
            "cross_filter_groups": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "bookmark_states": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "data_requirements": {
          "type": "object",
          "description": "Minimum data shape for layout to make sense. Strategist filters out layouts whose requirements the model can't satisfy.",
          "additionalProperties": false,
          "properties": {
            "min_rows": {
              "type": "integer",
              "minimum": 0
            },
            "required_measures": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "required_dimensions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "date_grain": {
              "type": "string",
              "enum": [
                "none",
                "day",
                "week",
                "month",
                "quarter",
                "year",
                "any"
              ]
            }
          }
        },
        "avoid_when": {
          "type": "string",
          "description": "Anti-pattern guidance — inverse of use_when. Explains when this layout is wrong.",
          "minLength": 1
        },
        "chart_patterns": {
          "type": "array",
          "description": "Canonical chart-pattern ids (from assets/chart-previews/) used by hero/supporting visuals. Lets Executor pull canonical chart spec rather than re-inventing.",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "uniqueItems": true
        },
        "example_pbips": {
          "type": "array",
          "description": "Relative paths to reference .pbip files in the workspace that exemplify this layout. Supports navigation into live examples.",
          "items": {
            "type": "string",
            "pattern": "^references-pbip/.+\\.pbip$"
          }
        },
        "last_reviewed_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "ISO date of last curation review."
        },
        "owner": {
          "type": "string",
          "description": "Team / individual accountable for keeping the layout current."
        },
        "derived_from": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "Parent layout id — e.g. `exec-overview-16x9-mobile` derives from `exec-overview-16x9`."
        },
        "preview_dark": {
          "type": "string",
          "pattern": "^[a-z0-9\\-]+\\.svg$",
          "description": "Dark-mode preview variant (assets/layout-previews/<id>-dark.svg)."
        },
        "preview_annotated": {
          "type": "string",
          "pattern": "^[a-z0-9\\-]+\\.svg$",
          "description": "Annotated preview with numbered callouts per zone_detail (assets/layout-previews/<id>-annotated.svg)."
        }
      }
